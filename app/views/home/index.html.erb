<body class="bg-gray-50">

<!-- Hero Section -->
<section class="hero-gradient text-white py-10 mt-41">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between">
      <div class="max-w-lg">
        <h1 class="text-5xl font-bold mb-4">Summer Sale</h1>
        <p class="text-xl mb-6">Up to 70% off on trending products</p>
        <p class="text-lg mb-8">Discover amazing deals on electronics, fashion, and more!</p>
        <%= link_to "Shop Now", "javascript:void(0)",
                    class: "bg-white text-primary-blue px-8 py-3 rounded-lg font-bold hover:bg-gray-100 inline-block" %>
      </div>
      <div class=" lg:block">
        <img src="https://plus.unsplash.com/premium_photo-1671721437895-b1334ee54723?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1yZWxhdGVkfDJ8fHxlbnwwfHx8fHw%3D"
             alt="Shopping" class="rounded-lg shadow">
      </div>
    </div>
  </div>
</section>

<!-- Trust Badges Section -->
<section class="bg-white py-6 border-b border-gray-200">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
      <div class="flex items-center justify-center space-x-3">
        <i class="fas fa-shipping-fast text-2xl text-green-600"></i>
        <div>
          <h3 class="font-semibold">Free Shipping</h3>
          <p class="text-sm text-gray-600">Orders over $50</p>
        </div>
      </div>
      <div class="flex items-center justify-center space-x-3">
        <i class="fas fa-undo text-2xl text-blue-600"></i>
        <div>
          <h3 class="font-semibold">Easy Returns</h3>
          <p class="text-sm text-gray-600">30-day return policy</p>
        </div>
      </div>
      <div class="flex items-center justify-center space-x-3">
        <i class="fas fa-shield-alt text-2xl text-primary-blue"></i>
        <div>
          <h3 class="font-semibold">Secure Payment</h3>
          <p class="text-sm text-gray-600">SSL encrypted</p>
        </div>
      </div>
      <div class="flex items-center justify-center space-x-3">
        <i class="fas fa-headset text-2xl text-orange-600"></i>
        <div>
          <h3 class="font-semibold">24/7 Support</h3>
          <p class="text-sm text-gray-600">Always here to help</p>
        </div>
      </div>
    </div>
  </div>
</section>

