<div class="flex flex-cols w-full items-center justify-center bg-base-200 border-base-300 rounded-box border p-4 mt-44">
  <div class="max-w-md w-full bg-white rounded-2xl shadow-xl overflow-hidden">
    <!-- Header Section -->
    <div class="bg-gradient-to-r from-accent-content/30 to-accent py-8 px-6 rounded-box text-center">
      <h2 class="text-3xl font-bold text-white mb-2">Admin Login</h2>
      <p class="text-blue-100 opacity-90">Sign in to access admin dashboard</p>
    </div>
    <!-- Form Section -->

    <div class="px-8 py-8">
      <%= form_for(resource, as: resource_name, url: admin_session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <!-- Email Field -->
        <div class="space-y-2">
          <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 relative rounded-md shadow-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-solid fa-envelope text-accent"></i>
            </div>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                              class: "focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 pr-3 py-3 border-gray-300 rounded-md text-gray-700",
                              placeholder: "admin@example.com" %>
          </div>
        </div>

        <!-- Password Field -->
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Forgot password?", new_password_path(resource_name),
                          class: "text-sm text-accent hover:text-accent-content/70 transition-colors" %>
            <% end %>
          </div>
          <div class="mt-1 relative rounded-md shadow-sm text-gray-500">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <i class="fa-solid fa-lock text-accent"></i>
            </div>
            <%= f.password_field :password, autocomplete: "current-password",
                                 class: "focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 pr-3 py-3 border-gray-300 rounded-md",
                                 placeholder: "Enter your password" %>
          </div>
        </div>

        <!-- Remember Me Checkbox -->
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
            <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-700" %>
          </div>
        <% end %>

        <!-- Submit Button -->
        <div>
          <%= f.submit "Log in to Dashboard",
                       class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gradient-to-r from-accent-content/20 to-accent text-center hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <!-- Separator -->
      <div class="mt-6 text-center">
        <p class="text-sm text-gray-600">
          Need an admin account? Contact your system administrator.
        </p>
      </div>
    </div>
  </div>
</div>