<% content_for :title, "New Product" %>

<div class="max-w-5xl mx-auto bg-white rounded-3xl shadow-2xl p-10">
  <!-- Header -->
  <div class="mb-8 text-center">
    <h1 class="text-4xl font-extrabold text-gray-800 tracking-tight">
      <i class="fa-solid fa-plus"></i> New Product
    </h1>
    <p class="mt-2 text-gray-500">Fill in the details below to add a new product</p>
  </div>

  <!-- Product Form -->
  <%= render "form", admin_product: @admin_product %>

  <!-- Actions -->
  <div class="mt-10 flex flex-col sm:flex-row sm:justify-center gap-4">

    <%= link_to admin_products_path,
                class: "w-full sm:w-auto inline-block text-center px-6 py-3 rounded-2xl bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 shadow-md transition-all duration-300" do %>
      <i class="fa-solid fa-arrow-left"></i> Back to Products
    <% end %>
  </div>
</div>
