<% content_for :title, "Editing Product" %>

<div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-2xl p-10">
  <!-- Header -->
  <div class="mb-8 text-center">
    <h1 class="text-4xl font-extrabold text-gray-800 tracking-tight">
      <i class="fa-solid fa-pen"></i> Edit Product
    </h1>
    <p class="mt-2 text-gray-500">Update product details and save your changes</p>
  </div>

  <!-- Product Form -->
  <%= render "form", admin_product: @admin_product %>

  <!-- Actions -->
  <div class="mt-10 flex flex-col sm:flex-row sm:justify-center gap-4">

    <%= link_to @admin_product,
                class: "w-full sm:w-auto inline-block text-center px-6 py-3 rounded-2xl bg-white border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 shadow-md transition-all duration-300" do %>
      <i class="fa-solid fa-eye"></i> View Product
    <% end %>

    <%= link_to admin_products_path,
                class: "w-full sm:w-auto inline-block text-center px-6 py-3 rounded-2xl bg-gray-100 text-gray-700 font-medium hover:bg-gray-200 shadow-md transition-all duration-300" do %>
    <i class="fa-solid fa-arrow-left"></i> Back to Products
    <% end %>
  </div>
</div>
