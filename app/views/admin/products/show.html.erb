<% content_for :title, "Product Details" %>

<div class="max-w-7xl mx-auto space-y-8">
  <!-- Notice -->
  <% if notice.present? %>
    <div class="flex items-center gap-3 px-6 py-4 bg-emerald-50 border-l-4 border-emerald-400 text-emerald-700 font-medium rounded-r-lg shadow-sm">
      <i class="fa-solid fa-circle-check text-emerald-500"></i>
      <%= notice %>
    </div>
  <% end %>

  <!-- Main Product Card -->
  <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
    <!-- Header -->
    <div class="bg-gradient-to-r from-slate-800 to-slate-700 px-8 py-6">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold text-white flex items-center gap-3">
            <i class="fa-solid fa-box text-blue-400"></i>
            <%= @admin_product.name %>
          </h1>
          <p class="text-slate-200 mt-2">Product ID: #<%= @admin_product.id %></p>
        </div>
        <div class="text-right">
          <% if @admin_product.active? %>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-green-500 text-white rounded-full text-sm font-semibold">
              <i class="fa-solid fa-check-circle"></i> Active
            </span>
          <% else %>
            <span class="inline-flex items-center gap-2 px-4 py-2 bg-red-500 text-white rounded-full text-sm font-semibold">
              <i class="fa-solid fa-times-circle"></i> Inactive
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="p-8">
      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Left: Image Gallery -->
        <div class="lg:col-span-1">
          <div class="sticky top-4">
            <% if @admin_product.images.attached? %>
              <div class="space-y-4">
                <div class="aspect-square rounded-2xl overflow-hidden shadow-lg">
                  <%= image_tag @admin_product.images.first,
                                class: "w-full h-full object-cover hover:scale-105 transition-transform duration-300" %>
                </div>
                <% if @admin_product.images.count > 1 %>
                  <div class="grid grid-cols-3 gap-3">
                    <% @admin_product.images.drop(1).first(3).each do |image| %>
                      <div class="aspect-square rounded-lg overflow-hidden shadow-md">
                        <%= image_tag image, class: "w-full h-full object-cover" %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="aspect-square bg-gray-100 rounded-2xl flex items-center justify-center shadow-lg">
                <div class="text-center text-gray-400">
                  <i class="fa-solid fa-image text-6xl mb-4"></i>
                  <p class="text-lg font-medium">No Images Available</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Middle: Product Information -->
        <div class="lg:col-span-1 space-y-6">
          <div class="bg-slate-50 rounded-xl p-6">
            <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
              <i class="fa-solid fa-info-circle text-blue-500"></i>
              Product Details
            </h2>

            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-slate-600 mb-1">Description</label>
                <p class="text-slate-800 leading-relaxed">
                  <%= @admin_product.description.present? ? @admin_product.description : "No description available" %>
                </p>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-slate-600 mb-1">Price</label>
                  <div class="text-2xl font-bold text-green-600">
                    $<%= number_to_currency(@admin_product.price, unit: "") %>
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-slate-600 mb-1">Category</label>
                  <div class="text-slate-800 font-medium">
                    <%= @admin_product.category&.name || "Uncategorized" %>
                  </div>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-slate-600 mb-1">Created</label>
                <div class="text-slate-600">
                  <%= @admin_product.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Stock Information -->
        <div class="lg:col-span-1 space-y-6">
          <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-xl font-bold text-slate-800 flex items-center gap-2">
                <i class="fa-solid fa-warehouse text-blue-500"></i>
                Stock Overview
              </h2>
              <%= link_to admin_product_stocks_path(@admin_product),
                          class: "text-blue-600 hover:text-blue-800 font-medium text-sm flex items-center gap-1" do %>
                <i class="fa-solid fa-cog"></i> Manage
              <% end %>
            </div>

            <div class="space-y-4">
              <!-- Stock Summary -->
              <div class="bg-white rounded-lg p-4 shadow-sm">
                <div class="grid grid-cols-2 gap-4 text-center">
                  <div>
                    <div class="text-2xl font-bold text-slate-800"><%= @admin_product.total_stock %></div>
                    <div class="text-sm text-slate-600">Total Units</div>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-slate-800"><%= @admin_product.stocks.count %></div>
                    <div class="text-sm text-slate-600">Size Variants</div>
                  </div>
                </div>
              </div>

              <!-- Stock Status -->
              <div class="bg-white rounded-lg p-4 shadow-sm">
                <% if @admin_product.available? %>
                  <div class="flex items-center gap-2 text-green-600 mb-2">
                    <i class="fa-solid fa-check-circle"></i>
                    <span class="font-semibold">In Stock</span>
                  </div>
                  <p class="text-sm text-slate-600">
                    Available in <%= pluralize(@admin_product.available_sizes.count, 'size') %>
                  </p>
                <% else %>
                  <div class="flex items-center gap-2 text-red-600 mb-2">
                    <i class="fa-solid fa-exclamation-triangle"></i>
                    <span class="font-semibold">Out of Stock</span>
                  </div>
                  <p class="text-sm text-slate-600">No items available</p>
                <% end %>
              </div>

              <!-- Individual Stock Items -->
              <% if @admin_product.stocks.any? %>
                <div class="bg-white rounded-lg p-4 shadow-sm">
                  <h3 class="font-semibold text-slate-800 mb-3">Stock by Size</h3>
                  <div class="space-y-2 max-h-40 overflow-y-auto">
                    <% @admin_product.stocks.by_size.each do |stock| %>
                      <div class="flex items-center justify-between py-2 px-3 bg-slate-50 rounded">
                        <span class="font-medium text-slate-700">Size <%= stock.size %></span>
                        <div class="flex items-center gap-2">
                          <span class="text-slate-600"><%= stock.amount %> units</span>
                          <% if stock.available? %>
                            <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                          <% else %>
                            <div class="w-2 h-2 bg-red-500 rounded-full"></div>
                          <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <div class="bg-white rounded-lg p-6 shadow-sm text-center">
                  <i class="fa-solid fa-inbox text-3xl text-slate-300 mb-3"></i>
                  <p class="text-slate-500 font-medium">No stock entries</p>
                  <p class="text-sm text-slate-400 mb-4">Add stock to start tracking inventory</p>
                  <%= link_to "Add Stock", new_admin_product_stock_path(@admin_product),
                              class: "inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium" %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Bar -->
    <div class="bg-slate-50 px-8 py-6 border-t border-slate-200">
      <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
        <%= link_to edit_admin_product_path(@admin_product),
                    class: "inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 shadow-md transition-all duration-200" do %>
          <i class="fa-solid fa-pen"></i> Edit Product
        <% end %>

        <%= link_to admin_product_stocks_path(@admin_product),
                    class: "inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-700 shadow-md transition-all duration-200" do %>
          <i class="fa-solid fa-warehouse"></i> Manage Stock
        <% end %>

        <%= link_to admin_products_path,
                    class: "inline-flex items-center gap-2 px-6 py-3 bg-slate-500 text-white font-semibold rounded-lg hover:bg-slate-600 shadow-md transition-all duration-200" do %>
          <i class="fa-solid fa-arrow-left"></i> Back to Products
        <% end %>

        <%= button_to @admin_product, method: :delete,
                      form_class: "inline-block",
                      class: "inline-flex items-center gap-2 px-6 py-3 bg-red-600 text-white font-semibold rounded-lg hover:bg-red-700 shadow-md transition-all duration-200 cursor-pointer",
                      data: { turbo_confirm: "Are you sure you want to delete this product and all its stock?" } do %>
          <i class="fa-solid fa-trash"></i> Delete Product
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Stock Actions (if product has stock) -->
  <% if @admin_product.stocks.any? %>
    <div class="bg-white rounded-2xl shadow-lg p-6">
      <h2 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
        <i class="fa-solid fa-bolt text-yellow-500"></i>
        Quick Stock Actions
      </h2>

      <div class="grid md:grid-cols-3 gap-4">
        <!-- Low Stock Alert -->
        <div class="bg-orange-50 border border-orange-200 rounded-lg p-4">
          <% low_stock_items = @admin_product.stocks.where('amount < 5 AND amount > 0') %>
          <h3 class="font-semibold text-orange-800 mb-2">Low Stock Alert</h3>
          <% if low_stock_items.any? %>
            <p class="text-sm text-orange-600 mb-2"><%= pluralize(low_stock_items.count, 'item') %> running low</p>
            <% low_stock_items.each do |stock| %>
              <div class="text-xs text-orange-700">Size <%= stock.size %>: <%= stock.amount %> left</div>
            <% end %>
          <% else %>
            <p class="text-sm text-orange-600">All items well stocked</p>
          <% end %>
        </div>

        <!-- Out of Stock -->
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <% out_of_stock = @admin_product.stocks.out_of_stock %>
          <h3 class="font-semibold text-red-800 mb-2">Out of Stock</h3>
          <% if out_of_stock.any? %>
            <p class="text-sm text-red-600 mb-2"><%= pluralize(out_of_stock.count, 'size') %> unavailable</p>
            <% out_of_stock.each do |stock| %>
              <div class="text-xs text-red-700">Size <%= stock.size %></div>
            <% end %>
          <% else %>
            <p class="text-sm text-red-600">All sizes in stock</p>
          <% end %>
        </div>

        <!-- Top Sizes -->
        <div class="bg-green-50 border border-green-200 rounded-lg p-4">
          <% top_sizes = @admin_product.stocks.available.order(amount: :desc).limit(3) %>
          <h3 class="font-semibold text-green-800 mb-2">Best Stocked</h3>
          <% if top_sizes.any? %>
            <% top_sizes.each do |stock| %>
              <div class="text-xs text-green-700 mb-1">
                Size <%= stock.size %>: <%= stock.amount %> units
              </div>
            <% end %>
          <% else %>
            <p class="text-sm text-green-600">No stock available</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>