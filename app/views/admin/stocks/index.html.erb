<!-- app/views/admin/stocks/index.html.erb -->
<div class="bg-white shadow-lg rounded-lg">
  <div class="px-6 py-4 border-b border-gray-200">
    <div class="flex justify-between items-center">
      <h1 class="text-2xl font-bold text-gray-900">Stock Management</h1>
      <%= link_to "Add New Stock", new_admin_product_stock_path(@admin_product),
                  class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md" %>
    </div>
    <p class="text-gray-600 mt-1">Managing stock for: <strong><%= @admin_product.name %></strong></p>
  </div>

  <div class="p-6">
    <% if @stocks.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Size</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
          <% @stocks.each do |stock| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                Size <%= stock.size %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= stock.amount %> units
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% if stock.available? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      In Stock
                    </span>
                <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Out of Stock
                    </span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
                <%= link_to "Edit", edit_admin_product_stock_path(@admin_product, stock),
                            class: "text-blue-600 hover:text-blue-900" %>
                <%= link_to "Delete", admin_product_stock_path(@admin_product, stock),
                            data: {
                              turbo_method: :delete,
                              turbo_confirm: "Are you sure?"
                            },
                            class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-6 bg-gray-50 p-4 rounded-lg">
        <h3 class="text-sm font-medium text-gray-900">Stock Summary</h3>
        <p class="text-sm text-gray-600">Total Stock: <strong><%= @admin_product.total_stock %> units</strong></p>
        <p class="text-sm text-gray-600">Available Sizes: <strong><%= @admin_product.available_sizes.join(', ') %></strong></p>
      </div>
    <% else %>
      <div class="text-center py-12">
        <h3 class="mt-2 text-sm font-medium text-gray-900">No stock entries</h3>
        <p class="mt-1 text-sm text-gray-500">Get started by creating a new stock entry.</p>
        <div class="mt-6">
          <%= link_to "Add Stock", new_admin_product_stock_path(@admin_product),
                      class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="px-6 py-4 border-t border-gray-200 bg-gray-50">
    <%= link_to "← Back to Products", admin_products_path,
                class: "text-gray-600 hover:text-gray-900 font-medium" %>
  </div>
</div>
