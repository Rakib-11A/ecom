<aside class="w-1/6 h-screen bg-gradient-to-b from-emerald-50 to-white border-r border-emerald-200 overflow-y-auto shadow-lg"
       data-sidebar-target="aside"
>
  <nav class="h-full flex flex-col px-4 transition-all duration-500 ease-in-out"
  >
    <!-- Header Section -->
    <div class="flex py-6 items-center border-b border-emerald-100 mb-6">
      <div class="flex-grow">
        <%= link_to admin_root_path, class: "text-emerald-800 font-bold text-2xl flex gap-3 items-center hover:text-emerald-600 transition-colors" do %>
          <div class="bg-emerald-100 p-2 rounded-lg">
            <i class="fa-solid fa-user-shield text-emerald-600 text-xl"></i>
          </div>
          <h1 class="sidebar-label">MedAdmin</h1>
        <% end %>
      </div>
      <button class="text-emerald-600 text-xl hover:text-emerald-800 transition-colors cursor-pointer"
              data-action="click->sidebar#toggle"
      >
        <i class="fa-solid fa-chevron-left"></i>
      </button>
    </div>

    <!-- Navigation Menu -->
    <div class="flex flex-col gap-2 overflow-y-auto">
      <p class="text-emerald-600 font-semibold text-sm uppercase tracking-wider mb-3">Navigation</p>

      <ul class="space-y-1">
        <!-- Dashboard -->
        <li class="group">
          <%= link_to admin_root_path, class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-blue-100 p-2 rounded-md group-hover:bg-blue-200 transition-colors">
              <i class="fa-solid fa-chart-line text-blue-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Dashboard</h1>
          <% end %>
        </li>

        <!-- Products/Medications -->
        <li class="group">
          <%= link_to admin_products_path, class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-green-100 p-2 rounded-md group-hover:bg-green-200 transition-colors">
              <i class="fa-solid fa-pills text-green-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Medications</h1>
          <% end %>
        </li>

        <!-- Categories -->
        <li class="group">
          <%= link_to admin_categories_path, class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-purple-100 p-2 rounded-md group-hover:bg-purple-200 transition-colors">
              <i class="fa-solid fa-sitemap text-purple-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Categories</h1>
          <% end %>
        </li>

        <!-- Orders/Prescriptions -->
        <li class="group">
          <%= link_to "javascript:void(0)", class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-amber-100 p-2 rounded-md group-hover:bg-amber-200 transition-colors">
              <i class="fa-solid fa-prescription-bottle text-amber-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Prescriptions</h1>
          <% end %>
        </li>

        <!-- Inventory -->
        <li class="group">
          <%= link_to "javascript:void(0)", class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-indigo-100 p-2 rounded-md group-hover:bg-indigo-200 transition-colors">
              <i class="fa-solid fa-boxes-stacked text-indigo-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Inventory</h1>
          <% end %>
        </li>

        <!-- Customers/Patients -->
        <li class="group">
          <%= link_to "javascript:void(0)", class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-rose-100 p-2 rounded-md group-hover:bg-rose-200 transition-colors">
              <i class="fa-solid fa-users text-rose-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Patients</h1>
          <% end %>
        </li>

        <!-- Reports -->
        <li class="group">
          <%= link_to "javascript:void(0)", class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
            <div class="bg-teal-100 p-2 rounded-md group-hover:bg-teal-200 transition-colors">
              <i class="fa-solid fa-chart-pie text-teal-600 text-lg"></i>
            </div>
            <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Reports</h1>
          <% end %>
        </li>
      </ul>

      <!-- Settings Section -->
      <div class="mt-8 pt-4 border-t border-emerald-100">
        <p class="text-emerald-600 font-semibold text-sm uppercase tracking-wider mb-3">Settings</p>

        <ul class="space-y-1">
          <li class="group">
            <%= link_to "javascript:void(0)", class: "flex gap-3 items-center px-3 py-3 rounded-lg hover:bg-emerald-100 transition-all duration-200 group-hover:shadow-sm" do %>
              <div class="bg-gray-100 p-2 rounded-md group-hover:bg-gray-200 transition-colors">
                <i class="fa-solid fa-cog text-gray-600 text-lg"></i>
              </div>
              <h1 class="text-gray-700 sidebar-label font-medium group-hover:text-gray-900">Settings</h1>
            <% end %>
          </li>
        </ul>
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-auto pt-4 border-t border-emerald-100">
      <div class="flex items-center gap-3 px-3 py-2">
        <div class="bg-emerald-100 p-2 rounded-full">
          <i class="fa-solid fa-user text-emerald-600"></i>
        </div>
        <div class="sidebar-label">
          <p class="text-sm font-medium text-gray-700">Admin User</p>
          <p class="text-xs text-gray-500">Online</p>
        </div>
      </div>
    </div>
  </nav>
</aside>